{
  "name": "chat-ag-ui",
  "version": "0.1.0",
  "description": "Headless React library for AG-UI protocol chat interfaces",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "cd demo && vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "build:demo": "cd demo && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:visual": "playwright test -c playwright.config.ts",
    "test:visual:update": "playwright test -c playwright.config.ts --update-snapshots",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "@ag-ui/client": ">=0.0.1",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@ag-ui/client": "^0.0.47",
    "@playwright/experimental-ct-react": "^1.49.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^28.1.0",
    "msw": "^2.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "ag-ui",
    "chat",
    "react",
    "headless",
    "hooks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:PiotrMieszczak/chat_ag_ui.git"
  },
  "packageManager": "yarn@4.6.0+sha512.5383cc12567a95f1d668fbe762dfe0075c595b4bfff433be478dbbe24e05251a8e8c3eb992a986667c1d53b6c3a9c85b8398c35a960587fbd9fa3a0915406728"
}
